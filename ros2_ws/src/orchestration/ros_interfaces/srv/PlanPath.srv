# RFC004 planner interface for exec->planner calls.

# Request
string goal_id
string task_type
string route_id
int32[] target_tags
int32 start_tag
ros_interfaces/Constraints constraints
int64 deadline_ms
bool allow_partial
string replan_reason
---
# Response
string plan_id
ros_interfaces/Segment[] segments
int32 next_tag
string error_code
string message
